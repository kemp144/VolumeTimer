<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  QuietLater.entitlements

  ENTITLEMENT RATIONALE:

  com.apple.security.app-sandbox = true
    Required for Mac App Store distribution.

  NO additional entitlements are required.

  CoreAudio system volume control (AudioObjectGetPropertyData /
  AudioObjectSetPropertyData with kAudioDevicePropertyVolumeScalar
  and kAudioDevicePropertyMute) works fully within the default
  sandbox without any extra entitlements.

  This app does NOT need:
    - com.apple.security.device.audio-input (microphone — not used)
    - com.apple.security.automation.apple-events (AppleScript — not used)
    - com.apple.security.temporary-exception.* (no exceptions needed)
    - Accessibility permissions (not used)
    - Full Disk Access (not used)
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
</dict>
</plist>
