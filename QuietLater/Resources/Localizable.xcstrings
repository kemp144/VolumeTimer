    "A calm, focused utility for controlling your Mac's volume — now or after a timer." : {
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et roligt og fokuseret værktøj til at styre lydstyrken på din Mac nu eller med en timer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein ruhiges, fokussiertes Tool, das die Lautstärke deines Macs sofort oder per Timer steuert."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una utilidad tranquila y precisa para controlar el volumen de tu Mac ahora o con un temporizador."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rauhallinen ja viimeistelty apuohjelma Macin äänenvoimakkuuden säätöön heti tai ajastetusti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un utilitaire calme et soigné pour gérer le volume de votre Mac, tout de suite ou avec un minuteur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un'utility discreta e curata per controllare il volume del tuo Mac subito o con un timer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Macの音量を今すぐ、またはタイマーで調整できる、落ち着いた使い心地のユーティリティです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 바로 또는 타이머로 Mac 볼륨을 조절할 수 있는 차분하고 세련된 유틸리티입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et rolig og fokusert verktøy for å styre volumet på Macen din nå eller med en timer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een rustige, verfijnde app om het volume van je Mac nu of later met een timer te regelen."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um utilitário calmo e refinado para controlar o volume do seu Mac agora ou com um temporizador."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett lugnt och genomtänkt verktyg för att styra volymen på din Mac nu eller med en timer."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一款安静、专注的实用工具，可立即或通过计时器控制你的 Mac 音量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一款安靜、專注的工具，可立即或透過計時器控制你的 Mac 音量。"
          }
        }
      }
    },
