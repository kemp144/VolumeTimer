          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuietLater schaltet deinen Mac in %1$@ stumm (um %2$@) und stellt die Lautstärke %3$ld Min. später wieder her."
          }
